# SAP HANA Cloud
HANA_HOST=your-hana-host.hanacloud.ondemand.com
HANA_PORT=443
HANA_USER=DBADMIN
HANA_PASSWORD=your_password_here
HANA_SCHEMA=your_schema_name
HANA_POOL_MIN=2
HANA_POOL_MAX=10

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Your Company Name
SENDGRID_VERIFIED_SENDERS=[{"email":"marketing@hatchevent.com","name":"HatchEvent"}]
SENDGRID_REPLY_TO_EMAIL=vendors@hatchevent.com
SENDGRID_REPLY_TO_NAME=
SENDGRID_WEBHOOK_PUBLIC_KEY=your_sendgrid_webhook_verification_public_key

# Firebase (server-side Admin SDK)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase (client-side — safe to expose, prefixed NEXT_PUBLIC_)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:XXXXXXXXXXXXXXXXXXXXXXX

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
